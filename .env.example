# Supabase credentials — find both under your Supabase project's
# Settings → API. Copy this file to .env.local and fill in the real values.
# Both are safe to expose to the browser (see SECURITY.md).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

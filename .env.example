# All variables here are SERVER-ONLY (no NEXT_PUBLIC_ prefix). The browser
# never talks to Supabase directly — every DB access goes through the Next.js
# API routes — so none of these values are bundled into client JS.
# Copy this file to .env.local and fill in the real values.

# Supabase project URL and anon key: Supabase → Settings → API.
# The anon key is constrained by the RLS policies in
# supabase/migrations/002_harden_rls.sql (read + submit only).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Service role key: Supabase → Settings → API → service_role.
# Bypasses RLS. Used only by admin-gated routes (see lib/admin.ts).
# Treat it like a database password.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret that admin callers must send as the x-admin-secret header
# to perform destructive operations (edit/delete items, manage dropdowns).
# Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_SECRET=your-admin-secret
